# ──────────────────────────────────────────────────────────────
# Rudy Workhorse — Environment Variables
#
# Copy this to .env and fill in real values.
# NEVER commit the .env file — it is in .gitignore.
#
# On Windows, set these as system environment variables:
#   setx RUDY_GMAIL_APP_PASSWORD "your-app-password"
# ──────────────────────────────────────────────────────────────

# Gmail (primary email provider)
RUDY_GMAIL_ADDRESS=rudy.ciminoassist@gmail.com
RUDY_GMAIL_APP_PASSWORD=

# Zoho (backup email provider)
RUDY_ZOHO_ADDRESS=rudy.ciminoassistant@zoho.com
RUDY_ZOHO_APP_PASSWORD=

# System password (for scheduled tasks, RustDesk, etc.)
RUDY_SYSTEM_PASSWORD=

# GitHub PAT (for repository operations)
GITHUB_PERSONAL_ACCESS_TOKEN=
