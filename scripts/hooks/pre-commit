#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────
# Pre-commit hook — quality gate for rudy-workhorse
#
# Runs automatically before every commit.  Rejects the commit if
# any check fails, so lint errors and test failures never reach
# the repository.
#
# Install:  scripts/hooks/install-hooks.sh
#           (or manually: cp scripts/hooks/pre-commit .git/hooks/)
# ──────────────────────────────────────────────────────────────

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'  # No Color

echo ""
echo "========================================"
echo "  Pre-commit quality gate"
echo "========================================"
echo ""

# Only check staged Python files (not the whole repo every time)
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY" ]; then
    echo -e "${GREEN}No Python files staged — skipping checks.${NC}"
    exit 0
fi

echo "Staged Python files:"
echo "$STAGED_PY" | sed 's/^/  /'
echo ""

FAILED=0

# ── Step 1: Ruff lint ────────────────────────────────────────
echo -e "${YELLOW}[1/3] Running ruff lint...${NC}"
# Try 'ruff' directly, fall back to 'python -m ruff'
RUFF_CMD=""
if command -v ruff &>/dev/null; then
    RUFF_CMD="ruff"
elif python -m ruff --version &>/dev/null 2>&1; then
    RUFF_CMD="python -m ruff"
fi

if [ -n "$RUFF_CMD" ]; then
    # Lint only the staged files, using the project's standard config
    if $RUFF_CMD check --select E,F,W --ignore E501,E402,F401 $STAGED_PY; then
        echo -e "${GREEN}  PASS: Lint clean${NC}"
    else
        echo -e "${RED}  FAIL: Lint errors found (see above)${NC}"
        echo -e "${YELLOW}  Tip: run 'ruff check --fix <file>' to auto-fix most issues${NC}"
        FAILED=1
    fi
else
    echo -e "${YELLOW}  SKIP: ruff not installed (pip install ruff)${NC}"
fi

# ── Step 2: Syntax check ────────────────────────────────────
echo -e "${YELLOW}[2/3] Checking syntax...${NC}"
SYNTAX_OK=1
for f in $STAGED_PY; do
    if [ -f "$f" ]; then
        if ! python -m py_compile "$f" 2>/dev/null; then
            echo -e "${RED}  FAIL: Syntax error in $f${NC}"
            SYNTAX_OK=0
            FAILED=1
        fi
    fi
done
if [ "$SYNTAX_OK" -eq 1 ]; then
    echo -e "${GREEN}  PASS: All files compile${NC}"
fi

# ── Step 3: Fast tests (only if tests/ files are staged) ────
STAGED_TESTS=$(echo "$STAGED_PY" | grep '^tests/' || true)
STAGED_RUDY=$(echo "$STAGED_PY" | grep -E '^(rudy/|scripts/)' || true)

if [ -n "$STAGED_TESTS" ] || [ -n "$STAGED_RUDY" ]; then
    echo -e "${YELLOW}[3/3] Running tests...${NC}"
    if command -v pytest &>/dev/null || python -m pytest --version &>/dev/null 2>&1; then
        if python -m pytest tests/ -x -q --tb=line --no-header 2>/dev/null; then
            echo -e "${GREEN}  PASS: All tests pass${NC}"
        else
            echo -e "${RED}  FAIL: Test failures detected${NC}"
            FAILED=1
        fi
    else
        echo -e "${YELLOW}  SKIP: pytest not installed (pip install pytest)${NC}"
    fi
else
    echo -e "${YELLOW}[3/3] No rudy/scripts/tests changes — skipping tests${NC}"
fi

# ── Verdict ──────────────────────────────────────────────────
echo ""
if [ "$FAILED" -eq 1 ]; then
    echo -e "${RED}========================================"
    echo "  COMMIT BLOCKED — fix errors above"
    echo -e "========================================${NC}"
    echo ""
    echo "To bypass in an emergency:  git commit --no-verify"
    exit 1
else
    echo -e "${GREEN}========================================"
    echo "  All checks passed"
    echo -e "========================================${NC}"
    exit 0
fi
