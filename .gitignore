# ===== Rudy / Workhorse .gitignore =====

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# Credentials & secrets (CRITICAL - never commit)
.env
*.env
rudy-totp-secret.json
rudy-logs/api-tokens.json
rudy-logs/api-server-config.json
rudy-logs/service-accounts.json
token.txt

# Logs & runtime state
rudy-logs/
rudy-commands/archive/
rudy-commands/*.result
rudy-commands/_runner.lock

# AI models (too large for git)
rudy-data/models/
rudy-data/avatar/models/

# Browser sessions & profiles
data/sessions/
data/browser-profile/

# Large data
*.onnx
*.bin
*.safetensors
*.gguf
*.pt
*.pth

# ChromaDB vector store
rudy-data/chromadb/
chroma_data/

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Results from command runner (contain runtime output)
*.result
*.result.json

# Health check state
ALERT-ACTIVE.txt
healthcheck-state.json

# Temp files
*.tmp
*.bak
*.old

# Node modules (if any)
node_modules/

# OS
.DS_Store

# Audit reports (generated, not source)
audit-reports/
health-reports/
briefings/

# Sprint/task planning (keep in repo root but not sub-outputs)
/projects/
!memory/projects/

# Binary/app exclusions (added 2026-03-27)
Tor Browser/
*.exe
*.dll
*.xpi
*.ja

# Robin runtime data (task queue, mailbox, watchdog)
rudy-data/robin-taskqueue/*.json
rudy-data/robin-taskqueue/.taskqueue.lock
rudy-data/robin-taskqueue/.last_seed
rudy-data/robin-taskqueue/completed/
rudy-data/robin-taskqueue/blocked/
rudy-data/robin-watchdog.log
rudy-data/alfred-inbox/
rudy-data/robin-inbox/
rudy-data/coordination/robin-status.json
rudy-data/environment-profile.json

# BatcaveVault — each Oracle's local memory (NEVER push to repo)
vault/
!vault/README.md

# S43: Temp artifacts from session work
rudy-data/executor-*.txt
rudy-data/s4[0-9]*
rudy-data/*-result*.json
rudy-data/*-final*.json
rudy-data/coordination/
rudy-data/inboxes/robin-inbox/*.json
rudy-data/git-*.json
rudy-data/handoff-*.json
rudy-data/final-*.json
Session-*-Handoff.md
Session-*-Prompt.md
*-Session-*-Prompt.md
scripts/*.log

# S43: n8n install artifacts
rudy-data/n8n-*.txt
rudy-data/n8n-*.json
rudy-data/n8n-*.ps1
rudy-data/n8n_*.py
rudy-data/npm-*.txt
rudy-data/node-*.txt

# S43: Old session helper scripts
rudy-data/s3[0-9]*.py
rudy-data/s43_*.py
rudy-data/s43_*.bat

# S43: Misc temp artifacts
rudy-data/pr[0-9]*.json
rudy-data/push-*.json
rudy-data/sync*.json
rudy-data/reg-*.txt
rudy-data/tier*.json
rudy-data/tob-*.json
rudy-data/tmp-*/
rudy-data/robin-continuous.log
rudy-data/lucius-self-audit-prompt.md
rudy-data/prompts/
